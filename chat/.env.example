# Environment Configuration
# Format: EULER_<FIELD> or EULER_<NESTED>__<FIELD>

# Debug mode
EULER_DEBUG=false

# Application name
EULER_APP_NAME=Chat API

# OpenAI API settings
EULER_OPENAI__API_KEY=your-api-key-here
EULER_OPENAI__API_BASE=https://api.openai.com/v1
EULER_OPENAI__MODEL=gpt-4o-mini

# Server settings
EULER_SERVER__HOST=0.0.0.0
EULER_SERVER__PORT=8000
